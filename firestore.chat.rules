// Klozy native chat — Firestore security rules for the `chat` collection.
//
// Conversations are keyed by BACKEND user ids, so the rules authorize by the
// `klozyUserId` custom claim (the backend sets it on the Firebase token during
// /v1/me provisioning) — NOT request.auth.uid (the Firebase uid).
//
// PASTE the `match /chat/{conversationId} { ... }` block below into your rules
// in the Firebase console, inside
//   service cloud.firestore { match /databases/{database}/documents { ... } }
// alongside your other collection rules, then PUBLISH. The NestJS backend uses
// the Admin SDK and bypasses these rules.

match /chat/{conversationId} {
  allow read: if request.auth != null
              && request.auth.token.klozyUserId in resource.data.participantIds;

  allow create: if request.auth != null
                && request.auth.token.klozyUserId in request.resource.data.participantIds;

  allow update: if request.auth != null
                && request.auth.token.klozyUserId in resource.data.participantIds
                && request.resource.data.participantIds == resource.data.participantIds;

  allow delete: if false;

  match /messages/{messageId} {
    function convParticipants() {
      return get(/databases/$(database)/documents/chat/$(conversationId)).data.participantIds;
    }

    allow read: if request.auth != null
                && request.auth.token.klozyUserId in convParticipants();

    allow create: if request.auth != null
                  && request.auth.token.klozyUserId == request.resource.data.senderId
                  && request.auth.token.klozyUserId in convParticipants();

    allow update: if request.auth != null
                  && request.auth.token.klozyUserId in convParticipants();

    allow delete: if false;
  }
}
